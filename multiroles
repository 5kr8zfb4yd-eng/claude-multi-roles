#!/usr/bin/env bash
# ═══ claude-multi-roles — Role selector with dynamic MCP ═══
# Usage: ./multiroles
# Repo: github.com/GiuseppeFarruggia/claude-multi-roles
set -e
cd "$(dirname "$0")"

# Load MCP credentials (never committed to git)
if [ -f .claude/.env.mcp ]; then
  set -a; source .claude/.env.mcp; set +a
fi

ROLES=(
  "1-Product Manager"
  "2-UI/UX Developer"
  "3-SWE"
  "4-Security Engineer"
  "5-Growth Marketer"
)
MCP_CONFIGS=(
  "1-product"
  "2-uiux"
  "3-swe"
  "4-security"
  "5-growth"
)

echo "═══════════════════════════════════════════════════════════"
echo "  claude-multi-roles — Select the session role"
echo "═══════════════════════════════════════════════════════════"
PS3="Role > "
select R in "${ROLES[@]}"; do
  [ -n "$R" ] && break
  echo "Invalid choice. Type the role number."
done

IDX=$((REPLY - 1))
CONFIG_FILE=".claude/mcp-configs/${MCP_CONFIGS[$IDX]}.json"

# Write the MCP configuration for this role
if [ -f "$CONFIG_FILE" ]; then
  if command -v envsubst &>/dev/null; then
    envsubst < "$CONFIG_FILE" > .mcp.json
  else
    cp "$CONFIG_FILE" .mcp.json
    echo "⚠️  envsubst not found — environment variables not substituted in the MCP config."
    echo "   Install it with: brew install gettext"
  fi
fi

# Show the active MCP servers
MCP_NAMES=$(python3 -c "
import json
try:
    cfg = json.load(open('.mcp.json'))
    s = list(cfg.get('mcpServers', {}).keys())
    print(', '.join(s) if s else 'none')
except: print('none')
" 2>/dev/null || echo "none")

echo ""
echo "◆ Active role:    $R"
echo "◆ MCP connectors: ${MCP_NAMES}"
echo ""

mkdir -p .claude/state
echo "$R" > .claude/state/active-role.txt

exec claude --dangerously-skip-permissions \
  "Activate the role: $R. Read CLAUDE.md, run the memory-reading protocol \
(ROLE.md → MEMORY.md → shared/STATE.md → shared/DECISIONS.md → last 20 events of \
shared/BUS.md). If any MCP servers are active, list the available tools. Then start the session."
